{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Compilar SFML 3 con Tolk",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-I", "${workspaceFolder}\\include",
                "-L", "${workspaceFolder}\\lib",
                "${workspaceFolder}\\*.cpp",
                "-o", "${workspaceFolder}\\main.exe",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "${workspaceFolder}\\Tolk.dll"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Configuración para SFML 3.0 y Tolk Accessibility"
        }
    ]
}